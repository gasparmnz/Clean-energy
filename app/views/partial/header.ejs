<link rel="stylesheet" href="/css/header.css">
<link rel="stylesheet" href="/css/darkmode.css">
<header class="header">
  <a href="/" class="logo">
    <img src="/imagem/logo-curva.svg" alt="Logo do site">
  </a>

  <input type="checkbox" id="check">
  <label for="check" class="icons">
    <i class="bx bx-menu" id="menu-icon"></i>
    <i class="bx bx-x" id="close-icon"></i>
  </label>

  <nav class="navbar">
    <a href="/" style="--i:0;">PRODUTOS</a>
    <a href="/sobre_nos" style="--i:1;">SOBRE NÓS</a>
    <a href="/transporte" style="--i:2;">TRANSPORTE</a>
  </nav>

  <section class="login-container">
    <% if (typeof usuario !== 'undefined' && usuario) { %>
      <% if (usuario.perfil === 'vendedor') { %>
        <a href="/cadastrar_produto" class="btn-vendedor">CADASTRAR PRODUTO</a>
      <% } else { %>
        <a href="/adicione_produto" class="btn-vendedor">TORNE-SE VENDEDOR</a>
        <span class="badge-perfil badge-comprador"><i class='bx bx-user'></i> Comprador</span>
      <% } %>

      <a href="/carrinho">
        <img class="carrinho" src="/imagem/carrinho.png" alt="Carrinho">
      </a>

      <section class="dropdown" id="dropdownBtn">
        <img src="<%= (typeof usuario !== 'undefined' && usuario && usuario.foto) ? (usuario.foto.startsWith('data:') ? usuario.foto : '/imagem/' + usuario.foto) : '/imagem/avatar.png' %>" alt="Usuário" class="avatar">
        <section id="dropdownMenu" class="dropdown-content">
          <span class="dropdown-nome"><%= usuario.nome %></span>
          <span class="dropdown-perfil"><%= usuario.perfil === 'vendedor' ? '🏪 Vendedor' : '🛒 Comprador' %></span>
          <hr>
          <a href="/perfil">Meu Perfil</a>
          <a href="/logout" style="color:#e74c3c;">Sair</a>
        </section>
      </section>

    <% } else { %>
      <a href="/adicione_produto" class="btn-vendedor">TORNE-SE VENDEDOR</a>

      <a href="/carrinho">
        <img class="carrinho" src="/imagem/carrinho.png" alt="Carrinho">
      </a>

      <span class="login-links">
        <a href="/login">LOGIN</a> | <a href="/cadastro">CADASTRE-SE</a>
      </span>

      <section class="dropdown" id="dropdownBtn">
        <img id="headerAvatar" src="<%= (typeof usuario !== 'undefined' && usuario && usuario.foto) ? (usuario.foto.startsWith('data:') ? usuario.foto : '/imagem/' + usuario.foto) : '/imagem/avatar.png' %>" alt="Usuário" class="avatar">
        <section id="dropdownMenu" class="dropdown-content">
          <a href="/login">Login</a>
          <a href="/cadastro">Cadastre-se</a>
        </section>
      </section>
    <% } %>
  </section>
</header>

<script src="/js/script.js"></script>
