<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usuários Cadastrados - Admin</title>
    <link rel="stylesheet" href="/css/adm.css">
    <link rel="stylesheet" href="/css/usuarios_cadastrados.css">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <%- include('../partial/header.ejs') %>
    <section class="admin-container">
        <!-- Sidebar -->
        <%- include('../partial/sidebar_adm.ejs') %>

        <!-- Main Content -->
        <main class="admin-main">

            <nav class="back-navigation" aria-label="Navegação de retorno">
        <button class="back-button" onclick="history.back()" aria-label="Voltar à página anterior">
          <i class='bx bx-arrow-back'></i>
          <span>Voltar</span>
        </button>
      </nav>
            <header class="page-header">
                <article>
                    <h1 class="page-title-green">Usuários Cadastrados</h1>
                    <p class="page-subtitle">Gerenciamento de todos usuários cadastrados no site</p>
                </article>
            </header>

                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nome</th>
                                <th>Email</th>
                                <th>Produto Principal</th>
                                <th>Total Vendas</th>
                                <th>Cadastro</th>
                                <th>Status</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                          <% if (Array.isArray(usuarios) && usuarios.length > 0) { %>
                            <% usuarios.forEach(function(u){ %>
                              <tr>
                                <td data-label="ID">USR-<%= u.id %></td>
                                <td data-label="Nome"><%= u.nome %></td>
                                <td data-label="Email"><%= u.email %></td>
                                <td data-label="Produto Principal">-</td>
                                <td data-label="Total Vendas" class="value-green">R$ 0,00</td>
                                <td data-label="Cadastro"><%= u.Data_Criacao ? new Date(u.Data_Criacao).toLocaleDateString('pt-BR') : '' %></td>
                                <td data-label="Status"><span class="status-badge status-ativo">-</span></td>
                                <td data-label="Ações">
                                    <nav class="action-buttons">
                                        <button class="action-icon view-icon" aria-label="Ver detalhes" onclick="verDetalhesUsuario('USR-<%= u.id %>')">
                                            <i class='bx bx-show'></i>
                                        </button>
                                    </nav>
                                </td>
                              </tr>
                            <% }) %>
                          <% } else { %>
                            <tr><td colspan="8" class="empty-state">Nenhum usuário cadastrado.</td></tr>
                          <% } %>
                        </tbody>
                                <td data-label="Ações">
                                    <nav class="action-buttons">
                                        <button class="action-icon view-icon" aria-label="Ver detalhes" onclick="verDetalhesUsuario('USR-004')">
                                            <i class='bx bx-show'></i>
                                        </button>
                                    </nav>
                                </td>
                            </tr>
                            <tr>
                                <td data-label="ID">USR-005</td>
                                <td data-label="Nome">Carlos Ferreira</td>
                                <td data-label="Email">carlos.f@agro.com</td>
                                <td data-label="Telefone">(16) 97123-4567</td>
                                <td data-label="Produto Principal">Palha de Milho</td>
                                <td data-label="Total Vendas" class="value-green">R$ 28.500,00</td>
                                <td data-label="Cadastro">15/11/2024</td>
                                <td data-label="Status"><span class="status-badge status-inativo">Inativo</span></td>
                                <td data-label="Ações">
                                    <nav class="action-buttons">
                                        <button class="action-icon view-icon" aria-label="Ver detalhes" onclick="verDetalhesUsuario('USR-005')">
                                            <i class='bx bx-show'></i>
                                        </button>
                                    </nav>
                                </td>
                            </tr>
                            <tr>
                                <td data-label="ID">USR-006</td>
                                <td data-label="Nome">Juliana Mendes</td>
                                <td data-label="Email">juliana.m@industria.com</td>
                                <td data-label="Telefone">(11) 96543-2109</td>
                                <td data-label="Produto Principal">Resíduos Florestais</td>
                                <td data-label="Total Vendas" class="value-green">R$ 67.900,00</td>
                                <td data-label="Cadastro">08/11/2024</td>
                                <td data-label="Status"><span class="status-badge status-ativo">Ativo</span></td>
                                <td data-label="Ações">
                                    <nav class="action-buttons">
                                        <button class="action-icon view-icon" aria-label="Ver detalhes" onclick="verDetalhesUsuario('USR-006')">
                                            <i class='bx bx-show'></i>
                                        </button>
                                    </nav>
                                </td>
                            </tr>
                            <tr>
                                <td data-label="ID">USR-007</td>
                                <td data-label="Nome">Roberto Alves</td>
                                <td data-label="Email">roberto.alves@fazenda.com</td>
                                <td data-label="Telefone">(85) 98234-5678</td>
                                <td data-label="Produto Principal">Casca de Coco</td>
                                <td data-label="Total Vendas" class="value-green">R$ 31.200,00</td>
                                <td data-label="Cadastro">01/11/2024</td>
                                <td data-label="Status"><span class="status-badge status-ativo">Ativo</span></td>
                                <td data-label="Ações">
                                    <nav class="action-buttons">
                                        <button class="action-icon view-icon" aria-label="Ver detalhes" onclick="verDetalhesUsuario('USR-007')">
                                            <i class='bx bx-show'></i>
                                        </button>
                                    </nav>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </article>
            </section>
        </main>
    </section>

    <script>
        function verDetalhesUsuario(userId) {
            window.location.href = `/adm/detalhes_user?userId=${userId}`;
        }
    </script>
    <script src="/js/darkmode.js"></script>
</body>
</html>