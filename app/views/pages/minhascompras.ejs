<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Minhas Compras</title>
  <link rel="stylesheet" href="/css/minhascompras.css">
  <link rel="stylesheet" href="/css/sidebar_perfil.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partial/header.ejs') %>

  <nav class="perfil-layout">
    <% const activePage = 'compras'; %>
    <%- include('../partial/sidebar_perfil.ejs') %>

    <main class="perfil-layout__content">
    <section class="content" style="padding: 0 16px;">
      <nav class="back-navigation" aria-label="Navegação de retorno">
        <button class="back-button" onclick="history.back()" aria-label="Voltar à página anterior">
          <i class='bx bx-arrow-back'></i>
          <span>Voltar</span>
        </button>
      </nav>

      

        <ul class="nav nav-tabs" id="productTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <a class="nav-link active" id="pendentesTab" data-bs-toggle="tab" href="#pendentes" role="tab" aria-controls="pendentes" aria-selected="true">Pendentes</a>
          </li>
          <li class="nav-item" role="presentation">
            <a class="nav-link" id="emAndamentoTab" data-bs-toggle="tab" href="#emAndamento" role="tab" aria-controls="emAndamento" aria-selected="false">Em trânsito</a>
          </li>
          <li class="nav-item" role="presentation">
            <a class="nav-link" id="concluidosTab" data-bs-toggle="tab" href="#concluidos" role="tab" aria-controls="concluidos" aria-selected="false">Concluídos</a>
          </li>
        </ul>

        <section class="tab-content" id="productTabsContent">

          <!-- PENDENTES -->
          <section class="tab-pane fade show active" id="pendentes" role="tabpanel" aria-labelledby="pendentesTab">
            <% if (!pendentes || pendentes.length === 0) { %>
              <div class="sem-itens">
                <i class='bx bx-package'></i>
                <p>Você não tem pedidos pendentes.</p>
              </div>
            <% } else { %>
              <section class="produtos-grid">
                <% pendentes.forEach(produto => { %>
                  <article class="produto-card"
                    data-nome="<%= produto.nome %>"
                    data-preco="<%= produto.preco %>"
                    data-quantidade="<%= produto.quantidade || 1 %>"
                    data-local="<%= produto.local || '' %>">
                    <figure>
                      <img src="/imagem/<%= produto.imagem %>" alt="<%= produto.nome %>" onerror="this.src='https://placehold.co/300x200?text=Sem+Foto'">
                    </figure>
                    <section class="produto-info">
                      <h3><%= produto.nome %></h3>
                      <p class="preco">R$ <%= parseFloat(produto.preco).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></p>
                      <p class="quantidade d-none"><%= produto.quantidade || 1 %> Tonelada(s)</p>
                      <p class="endereco d-none"><%= produto.local || '' %></p>
                    </section>
                    <section class="acoes">
                      <button class="btn btn-success btn-sm btn-pagar">Efetuar Pagamento</button>
                      <button class="btn btn-danger btn-sm btn-cancelar">Cancelar</button>
                    </section>
                    <p class="pendente">À pagar</p>
                  </article>
                <% }) %>
              </section>
            <% } %>
          </section>

          <!-- EM TRÂNSITO -->
          <section class="tab-pane fade" id="emAndamento" role="tabpanel" aria-labelledby="emAndamentoTab">
            <div class="sem-itens">
              <i class='bx bx-package'></i>
              <p>Você não tem pedidos em trânsito.</p>
            </div>
          </section>

          <!-- CONCLUÍDOS -->
          <section class="tab-pane fade" id="concluidos" role="tabpanel" aria-labelledby="concluidosTab">
            <div class="sem-itens">
              <i class='bx bx-package'></i>
              <p>Você não tem pedidos concluídos.</p>
            </div>
          </section>

        </section>
      </section>
    </main>
  </nav>

  <!-- MODAL PAGAMENTO -->
  <section class="modal fade" id="pagamentoModal" tabindex="-1" aria-labelledby="pagamentoModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered modal-xl">
      <section class="modal-content">
        <header class="modal-header">
          <h5 class="modal-title" id="pagamentoModalLabel">Efetuar Pagamento</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </header>
        <section class="modal-body">
          <section class="container-fluid">
            <section class="row">
              <section class="col-12 col-lg-5 border-end pe-lg-4 mb-3 mb-lg-0">
                <h6>Produto</h6>
                <p><strong>Nome:</strong> <span id="pagamento-produto"></span></p>
                <p><strong>Quantidade:</strong> <span id="pagamento-quantidade"></span></p>
                <p><strong>Valor:</strong> <span id="pagamento-valor"></span></p>
              </section>
              <section class="col-12 col-lg-7 ps-lg-4">
                <h6>Escolha a forma de pagamento</h6>
                <section class="d-flex flex-column flex-md-row gap-3 mb-3">
                  <button class="btn btn-outline-primary flex-fill payment-button" id="cardPix"><i class='bx bx-wallet'></i> Pix</button>
                  <button class="btn btn-outline-primary flex-fill payment-button" id="cardCredito"><i class='bx bx-credit-card'></i> Cartão</button>
                  <button class="btn btn-outline-primary flex-fill payment-button" id="cardBoleto"><i class='bx bx-file'></i> Boleto</button>
                </section>

                <section id="pixArea" class="p-3 border rounded mb-3" style="display:none;">
                  <section class="row align-items-center">
                    <section class="col-12 col-md-6 text-center">
                      <img id="pixQrcode" src="" alt="QR Code Pix (simulado)" style="max-width:220px;">
                    </section>
                    <section class="col-12 col-md-6">
                      <p><i class='bx bx-qrcode fs-3'></i> Escaneie o QR Code no seu app bancário.</p>
                      <p>Chave Pix: <strong id="pixKey">meuemail@dominio.com</strong></p>
                      <p><small class="text-muted">QR Code gerado apenas para simulação visual.</small></p>
                    </section>
                  </section>
                </section>

                <section id="creditoArea" class="p-3 border rounded mb-3" style="display:none;">
                  <section class="row g-3">
                    <section class="col-12 position-relative">
                      <label for="numeroCartao" class="form-label">Número do Cartão</label>
                      <i class='bx bx-credit-card position-absolute' style="top:38px; left:10px;"></i>
                      <input type="text" class="form-control ps-5" id="numeroCartao" placeholder="0000 0000 0000 0000">
                    </section>
                    <section class="col-6 position-relative">
                      <label for="validadeCartao" class="form-label">Validade</label>
                      <i class='bx bx-calendar position-absolute' style="top:38px; left:10px;"></i>
                      <input type="text" class="form-control ps-5" id="validadeCartao" placeholder="MM/AA">
                    </section>
                    <section class="col-6 position-relative">
                      <label for="cvvCartao" class="form-label">CVV</label>
                      <i class='bx bx-lock-alt position-absolute' style="top:38px; left:10px;"></i>
                      <input type="text" class="form-control ps-5" id="cvvCartao" placeholder="123">
                    </section>
                    <section class="col-12 position-relative">
                      <label for="nomeTitular" class="form-label">Nome do Titular</label>
                      <i class='bx bx-user position-absolute' style="top:38px; left:10px;"></i>
                      <input type="text" class="form-control ps-5" id="nomeTitular" placeholder="Nome impresso no cartão">
                    </section>
                  </section>
                  <p class="mt-2">Bandeiras aceitas: <i class='bx bxl-visa'></i> <i class='bx bxl-mastercard'></i> <i class='bx bxl-amex'></i></p>
                </section>

                <section id="boletoArea" class="p-3 border rounded mb-3" style="display:none;">
                  <section class="row g-2 align-items-center">
                    <section class="col-12 col-md-8">
                      <p><i class='bx bx-barcode fs-3'></i> Gere o boleto e pague em qualquer banco ou app.</p>
                      <p><small class="text-muted">Boleto simulado — válido por 3 dias.</small></p>
                    </section>
                    <section class="col-12 col-md-4 text-md-end">
                      <button class="btn btn-primary" id="gerarBoletoBtn">Gerar Boleto</button>
                    </section>
                    <section class="col-12 mt-2" id="boletoContainer" style="display:none;">
                      <input type="text" class="form-control sim-boleto text-center" id="boletoCodigo" readonly>
                      <p class="mt-2"><small class="text-muted">Copie o código do boleto para pagar.</small></p>
                    </section>
                  </section>
                </section>

                <section id="mensagemPagamentoErro" class="text-danger mt-2" style="display: none;"></section>
              </section>
            </section>
          </section>
        </section>
        <section class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-success" id="confirmarPagamento">Confirmar Pagamento</button>
        </section>
      </section>
    </section>
  </section>

  <!-- MODAL CANCELAR -->
  <section class="modal fade" id="cancelarModal" tabindex="-1" aria-labelledby="cancelarModalLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
      <section class="modal-content">
        <header class="modal-header">
          <h5 class="modal-title" id="cancelarModalLabel">Confirmar Cancelamento</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </header>
        <section class="modal-body">
          <p>Tem certeza que deseja cancelar este pedido?</p>
        </section>
        <section class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Não</button>
          <button type="button" class="btn btn-danger" id="confirmarCancelamento">Sim, cancelar</button>
        </section>
      </section>
    </section>
  </section>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const cancelarModal = new bootstrap.Modal(document.getElementById('cancelarModal'));
    const pagamentoModal = new bootstrap.Modal(document.getElementById('pagamentoModal'));
    let cardParaCancelar = null;
    let produtoSelecionadoParaPagamento = null;
    let selectedPaymentMethod = 'pix';

    // Cancelar
    document.querySelectorAll('.btn-cancelar').forEach(btn => {
      btn.addEventListener('click', function () {
        cardParaCancelar = this.closest('.produto-card');
        cancelarModal.show();
      });
    });

    document.getElementById('confirmarCancelamento').addEventListener('click', function () {
      if (cardParaCancelar) {
        cardParaCancelar.remove();
        // Se não há mais cards, mostra mensagem vazia
        const grid = document.querySelector('#pendentes .produtos-grid');
        if (grid && grid.querySelectorAll('.produto-card').length === 0) {
          grid.parentElement.innerHTML = `
            <div class="sem-itens">
              <i class='bx bx-package'></i>
              <p>Você não tem pedidos pendentes.</p>
            </div>`;
        }
      }
      cancelarModal.hide();
    });

    // Pagamento
    document.querySelectorAll('.btn-pagar').forEach(btn => {
      btn.addEventListener('click', function () {
        const card = this.closest('.produto-card');
        produtoSelecionadoParaPagamento = card;
        document.getElementById('pagamento-produto').textContent = card.querySelector('h3').textContent;
        document.getElementById('pagamento-quantidade').textContent = card.querySelector('.quantidade').textContent;
        document.getElementById('pagamento-valor').textContent = card.querySelector('.preco').textContent;
        document.getElementById('numeroCartao').value = '';
        document.getElementById('validadeCartao').value = '';
        document.getElementById('cvvCartao').value = '';
        document.getElementById('nomeTitular').value = '';
        document.getElementById('boletoCodigo').value = '';
        document.getElementById('boletoContainer').style.display = 'none';
        selectPayment('pix');
        pagamentoModal.show();
      });
    });

    function resetPaymentAreas() {
      ['pixArea','creditoArea','boletoArea'].forEach(id => document.getElementById(id).style.display = 'none');
      ['cardPix','cardCredito','cardBoleto'].forEach(id => {
        document.getElementById(id).classList.remove('btn-primary','selected-payment');
        document.getElementById(id).classList.add('btn-outline-primary');
      });
    }

    function selectPayment(method) {
      resetPaymentAreas();
      selectedPaymentMethod = method;
      if (method === 'pix') {
        document.getElementById('pixArea').style.display = 'block';
        document.getElementById('cardPix').classList.replace('btn-outline-primary','btn-primary');
        const fakeData = '000201010212...SIMULADOPIX...' + Date.now();
        document.getElementById('pixQrcode').src = 'https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=' + encodeURIComponent(fakeData);
        document.getElementById('confirmarPagamento').textContent = 'Verificar Pagamento';
      } else if (method === 'cartao') {
        document.getElementById('creditoArea').style.display = 'block';
        document.getElementById('cardCredito').classList.replace('btn-outline-primary','btn-primary');
        document.getElementById('confirmarPagamento').textContent = 'Confirmar Pagamento';
      } else if (method === 'boleto') {
        document.getElementById('boletoArea').style.display = 'block';
        document.getElementById('cardBoleto').classList.replace('btn-outline-primary','btn-primary');
        document.getElementById('confirmarPagamento').textContent = 'Verificar Pagamento';
      }
    }

    document.getElementById('cardPix').addEventListener('click', () => selectPayment('pix'));
    document.getElementById('cardCredito').addEventListener('click', () => selectPayment('cartao'));
    document.getElementById('cardBoleto').addEventListener('click', () => selectPayment('boleto'));

    document.getElementById('gerarBoletoBtn').addEventListener('click', () => {
      const fake = '2379' + Math.floor(Math.random() * 1e11).toString().padStart(11,'0') + '0000000000000000';
      document.getElementById('boletoCodigo').value = fake;
      document.getElementById('boletoContainer').style.display = 'block';
    });

    document.getElementById('confirmarPagamento').addEventListener('click', function () {
      const erroEl = document.getElementById('mensagemPagamentoErro');
      erroEl.style.display = 'none';

      if (selectedPaymentMethod === 'cartao') {
        const num   = document.getElementById('numeroCartao').value.trim();
        const val   = document.getElementById('validadeCartao').value.trim();
        const cvv   = document.getElementById('cvvCartao').value.trim();
        const nome  = document.getElementById('nomeTitular').value.trim();
        if (!num || !val || !cvv || !nome) {
          erroEl.textContent = 'Preencha os dados do cartão.';
          erroEl.style.display = 'block';
          return;
        }
      }

      // Pagamento ainda não real — apenas informa o usuário
      erroEl.textContent = 'Pagamento ainda não disponível. Em breve!';
      erroEl.style.display = 'block';
    });
  </script>

  <%- include('../partial/footer.ejs') %>
  <script src="/js/darkmode.js"></script>
</body>
</html>
