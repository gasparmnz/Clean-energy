      function renderLista(credenciais) {
        if (!credenciais || credenciais.length === 0) {
          lista.innerHTML = '<p style="color:#9ca3af; font-size:.85rem;">Nenhum dispositivo cadastrado ainda.</p>';
          return;
        }
        lista.innerHTML = credenciais.map(function (c) {
