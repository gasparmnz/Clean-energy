              lista.innerHTML = '<p style="color:#9ca3af; font-size:.85rem;">Recurso ainda não habilitado no servidor.</p>';
              btn.style.display = 'none';
              return;
            }
            renderLista(data.credenciais);
          })
          .catch(function () {
            lista.innerHTML = '<p style="color:#9ca3af; font-size:.85rem;">Não foi possível carregar os dispositivos.</p>';
