       btn.addEventListener('click', function () {
         const id = btn.dataset.id;
         btn.disabled = true;
         fetch('/pedidos/' + id + '/concluir', { method: 'POST' })
           .then(function (r) { return r.json(); })
           .then(function (data) {
             if (data.success) {
               location.reload();
             } else {
               btn.disabled = false;
               alert('Não foi possível concluir este pedido.');
             }
           })
           .catch(function () {
             btn.disabled = false;
             alert('Erro de conexão ao concluir o pedido.');
