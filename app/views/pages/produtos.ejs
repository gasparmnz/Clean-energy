<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Biomassa Hub - Produtos</title>
   <link rel="stylesheet" href="/css/produtos.css">
  <link rel="stylesheet" href="/css/carrossel.css">
  <link rel="stylesheet" href="/css/darkmode.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <link rel="apple-touch-icon" sizes="180x180" href="/imagem/logocleancompr.png.jpg">
  <link rel="icon" type="image/png" sizes="192x192" href="/imagem/logocleancompr.png.jpg">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:title" content="Clean Energy" />
  <meta property="og:description" content="Conheça o melhor site em energia limpa" />
  <meta property="og:type" content="website" />
  <style>
    .badge-perfil { font-size: 0.75rem; padding: 3px 10px; border-radius: 20px; font-weight: 600; }
    .badge-comprador { background:#e8f5e9; color:#2e7d32; }
    .badge-vendedor  { background:#fff3e0; color:#e65100; }
    .dropdown-nome { display:block; padding:8px 16px; font-weight:700; color:#333; }
    .dropdown-perfil { display:block; padding:0 16px 8px; font-size:0.8rem; color:#666; }
    .dropdown-content hr { margin:4px 0; border-color:#eee; }
    .acesso-restrito { background:#fff3e0; color:#e65100; padding:10px 18px; border-radius:8px; margin:12px 0; font-size:0.9rem; }
  </style>
</head>
<body>
  <%- include('../partial/header.ejs') %>

  <!-- ══ HERO CARROSSEL ══ -->
  <section class="hero-section" aria-label="Destaques do marketplace">

    <!-- Carrossel principal -->
    <section class="carrossel-wrapper" aria-label="Banners promocionais">

      <!-- Track -->
      <div class="carrossel-track" role="list">

        <!-- SLIDE 1: Biomassa Florestal -->
        <article class="carrossel-slide" role="listitem">
          <figure>
            <img
              src="https://image.pollinations.ai/prompt/aerial%20view%20eucalyptus%20forest%20biomass%20wood%20chips%20sustainable%20energy%20green%20brazil%20cinematic%20light?width=1400&height=480&seed=101&nologo=true"
              alt="Biomassa Florestal — Cavaco de Eucalipto"
              loading="eager"
              width="1400"
              height="480">
            <figcaption>
              <span class="slide-tag"><i class='bx bx-leaf'></i> Biomassa Florestal</span>
              <h2 class="slide-titulo">Cavaco de Eucalipto<br>e Madeira Nativa</h2>
              <p class="slide-subtitulo">Alta densidade energética, umidade controlada e entrega FOB em todo o Brasil.</p>
              <a href="/?categoria=biomassa-florestal" class="slide-cta">
                <i class='bx bx-search-alt'></i> Explorar produtos
              </a>
            </figcaption>
          </figure>
        </article>

        <!-- SLIDE 2: Bagaço de Cana -->
        <article class="carrossel-slide" role="listitem">
          <figure>
            <img
              src="https://image.pollinations.ai/prompt/sugarcane%20bagasse%20biomass%20energy%20production%20industrial%20bales%20sunset%20brazil%20farm%20cinematic?width=1400&height=480&seed=202&nologo=true"
              alt="Bagaço de Cana — Resíduos Agroindustriais"
              loading="lazy"
              width="1400"
              height="480">
            <figcaption>
              <span class="slide-tag"><i class='bx bx-sun'></i> Resíduos Agroindustriais</span>
              <h2 class="slide-titulo">Bagaço de Cana<br>para Geração de Energia</h2>
              <p class="slide-subtitulo">Resíduo de alta disponibilidade com excelente poder calorífico para usinas e indústrias.</p>
              <a href="/?categoria=residuos-agricolas" class="slide-cta">
                <i class='bx bx-search-alt'></i> Ver oferta
              </a>
            </figcaption>
          </figure>
        </article>

        <!-- SLIDE 3: Pellets -->
        <article class="carrossel-slide" role="listitem">
          <figure>
            <img
              src="https://image.pollinations.ai/prompt/biomass%20wood%20pellets%20close%20up%20renewable%20energy%20industrial%20clean%20background%20professional%20photography?width=1400&height=480&seed=303&nologo=true"
              alt="Pellets de Biomassa — Combustível Compacto"
              loading="lazy"
              width="1400"
              height="480">
            <figcaption>
              <span class="slide-tag"><i class='bx bx-cylinder'></i> Pellets & Briquetes</span>
              <h2 class="slide-titulo">Pellets de Biomassa<br>com Certificação</h2>
              <p class="slide-subtitulo">Combustível compacto, uniforme e de alta eficiência para caldeiras e fornos industriais.</p>
              <a href="/?categoria=materias-primas" class="slide-cta">
                <i class='bx bx-search-alt'></i> Comprar agora
              </a>
            </figcaption>
          </figure>
        </article>

        <!-- SLIDE 4: Palha e Resíduos -->
        <article class="carrossel-slide" role="listitem">
          <figure>
            <img
              src="https://image.pollinations.ai/prompt/rice%20straw%20bales%20agricultural%20residue%20bioenergy%20renewable%20harvest%20field%20golden%20hour%20brazil?width=1400&height=480&seed=404&nologo=true"
              alt="Palha e Resíduos Agrícolas — Energia Renovável"
              loading="lazy"
              width="1400"
              height="480">
            <figcaption>
              <span class="slide-tag"><i class='bx bx-seedling'></i> Resíduos Agrícolas</span>
              <h2 class="slide-titulo">Palha de Arroz e<br>Resíduos da Colheita</h2>
              <p class="slide-subtitulo">Matéria-prima sustentável disponível em grandes volumes após cada safra em todo o país.</p>
              <a href="/?categoria=residuos-organicos" class="slide-cta">
                <i class='bx bx-search-alt'></i> Ver disponibilidade
              </a>
            </figcaption>
          </figure>
        </article>

        <!-- SLIDE 5: Sustentabilidade -->
        <article class="carrossel-slide" role="listitem">
          <figure>
            <img
              src="https://image.pollinations.ai/prompt/green%20energy%20plant%20biomass%20power%20station%20sustainable%20renewable%20industrial%20aerial%20view%20brazil%20jungle%20cinematic?width=1400&height=480&seed=505&nologo=true"
              alt="Energia Limpa — Sustentabilidade e Futuro"
              loading="lazy"
              width="1400"
              height="480">
            <figcaption>
              <span class="slide-tag"><i class='bx bx-globe'></i> Energia Limpa</span>
              <h2 class="slide-titulo">O Futuro da Energia<br>começa aqui</h2>
              <p class="slide-subtitulo">Conectamos produtores e compradores de biomassa em todo o Brasil de forma simples e segura.</p>
              <a href="/cadastro" class="slide-cta">
                <i class='bx bx-user-plus'></i> Criar conta grátis
              </a>
            </figcaption>
          </figure>
        </article>

      </div><!-- /carrossel-track -->

      <!-- Setas -->
      <button class="carrossel-btn carrossel-btn-prev" aria-label="Slide anterior">
        <i class='bx bx-chevron-left'></i>
      </button>
      <button class="carrossel-btn carrossel-btn-next" aria-label="Próximo slide">
        <i class='bx bx-chevron-right'></i>
      </button>

    </section><!-- /carrossel-wrapper -->

    <!-- Dots -->
    <ul class="carrossel-dots" role="tablist" aria-label="Navegação do carrossel">
      <li><button class="carrossel-dot ativo" role="tab" aria-label="Slide 1"></button></li>
      <li><button class="carrossel-dot" role="tab" aria-label="Slide 2"></button></li>
      <li><button class="carrossel-dot" role="tab" aria-label="Slide 3"></button></li>
      <li><button class="carrossel-dot" role="tab" aria-label="Slide 4"></button></li>
      <li><button class="carrossel-dot" role="tab" aria-label="Slide 5"></button></li>
    </ul>

  </section>
  <!-- /hero-section -->

  <main>

    <% if (typeof filtros !== 'undefined' && typeof usuario === 'undefined' || !usuario) { %>
    <% } %>

    <!-- Filtro funcional via GET -->
    <section class="filtro-container">
      <form class="filtro-box" method="GET" action="/">

        <!-- Barra de busca com nome "Buscar produtos" -->
        <div class="filtro-topo">
          <i class='bx bx-search'></i>
          <input
            type="text"
            name="busca"
            placeholder="Buscar produtos..."
            value="<%= typeof filtros !== 'undefined' ? filtros.busca : '' %>"
          />
        </div>

        <!-- Filtros -->
        <div class="filtro-linha">
          <select name="estado">
            <option value="">Todos os estados</option>
            <option value="Acre" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Acre') ? 'selected' : '' %>>Acre</option>
            <option value="Alagoas" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Alagoas') ? 'selected' : '' %>>Alagoas</option>
            <option value="Amapá" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Amapá') ? 'selected' : '' %>>Amapá</option>
            <option value="Amazonas" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Amazonas') ? 'selected' : '' %>>Amazonas</option>
            <option value="Bahia" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Bahia') ? 'selected' : '' %>>Bahia</option>
            <option value="Ceará" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Ceará') ? 'selected' : '' %>>Ceará</option>
            <option value="Distrito Federal" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Distrito Federal') ? 'selected' : '' %>>Distrito Federal</option>
            <option value="Espírito Santo" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Espírito Santo') ? 'selected' : '' %>>Espírito Santo</option>
            <option value="Goiás" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Goiás') ? 'selected' : '' %>>Goiás</option>
            <option value="Maranhão" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Maranhão') ? 'selected' : '' %>>Maranhão</option>
            <option value="Mato Grosso" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Mato Grosso') ? 'selected' : '' %>>Mato Grosso</option>
            <option value="Mato Grosso do Sul" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Mato Grosso do Sul') ? 'selected' : '' %>>Mato Grosso do Sul</option>
            <option value="Minas Gerais" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Minas Gerais') ? 'selected' : '' %>>Minas Gerais</option>
            <option value="Pará" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Pará') ? 'selected' : '' %>>Pará</option>
            <option value="Paraíba" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Paraíba') ? 'selected' : '' %>>Paraíba</option>
            <option value="Paraná" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Paraná') ? 'selected' : '' %>>Paraná</option>
            <option value="Pernambuco" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Pernambuco') ? 'selected' : '' %>>Pernambuco</option>
            <option value="Piauí" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Piauí') ? 'selected' : '' %>>Piauí</option>
            <option value="Rio de Janeiro" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Rio de Janeiro') ? 'selected' : '' %>>Rio de Janeiro</option>
            <option value="Rio Grande do Norte" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Rio Grande do Norte') ? 'selected' : '' %>>Rio Grande do Norte</option>
            <option value="Rio Grande do Sul" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Rio Grande do Sul') ? 'selected' : '' %>>Rio Grande do Sul</option>
            <option value="Rondônia" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Rondônia') ? 'selected' : '' %>>Rondônia</option>
            <option value="Roraima" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Roraima') ? 'selected' : '' %>>Roraima</option>
            <option value="Santa Catarina" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Santa Catarina') ? 'selected' : '' %>>Santa Catarina</option>
            <option value="São Paulo" <%= (typeof filtros !== 'undefined' && filtros.estado === 'São Paulo') ? 'selected' : '' %>>São Paulo</option>
            <option value="Sergipe" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Sergipe') ? 'selected' : '' %>>Sergipe</option>
            <option value="Tocantins" <%= (typeof filtros !== 'undefined' && filtros.estado === 'Tocantins') ? 'selected' : '' %>>Tocantins</option>
          </select>

          <select name="categoria">
            <option value="">Categoria</option>
            <option value="materias-primas" <%= (typeof filtros !== 'undefined' && filtros.categoria === 'materias-primas') ? 'selected' : '' %>>Matérias-primas</option>
            <option value="residuos-organicos" <%= (typeof filtros !== 'undefined' && filtros.categoria === 'residuos-organicos') ? 'selected' : '' %>>Resíduos Orgânicos</option>
            <option value="biomassa-florestal" <%= (typeof filtros !== 'undefined' && filtros.categoria === 'biomassa-florestal') ? 'selected' : '' %>>Biomassa Florestal</option>
            <option value="residuos-agricolas" <%= (typeof filtros !== 'undefined' && filtros.categoria === 'residuos-agricolas') ? 'selected' : '' %>>Resíduos Agrícolas</option>
          </select>

          <input
            type="number"
            name="precoMin"
            placeholder="Preço mín."
            value="<%= typeof filtros !== 'undefined' ? filtros.precoMin : '' %>"
          />
          <input
            type="number"
            name="precoMax"
            placeholder="Preço máx."
            value="<%= typeof filtros !== 'undefined' ? filtros.precoMax : '' %>"
          />

          <button type="submit" style="padding:8px 18px;background:#2e7d32;color:#fff;border:none;border-radius:6px;cursor:pointer;font-weight:600;">
            <i class='bx bx-filter-alt'></i> Filtrar
          </button>
          <a href="/" style="padding:8px 14px;background:#eee;color:#333;border-radius:6px;text-decoration:none;font-size:0.85rem;">Limpar</a>
        </div>

      </form>
    </section>

    <ul class="produtos-scroll">
      <% if (produtos.length === 0) { %>

        <div class="sem-produtos">
          <i class='bx bx-package'></i>
          <h2>Nenhum produto encontrado</h2>
          <p>Tente ajustar os filtros ou <a href="/">ver todos os produtos</a>.</p>
        </div>

      <% } else { %>

        <% produtos.forEach(produto => { %>
          <li>
            <article class="produto-card" data-id="<%= produto.id %>">
              <figure>
                <a href="/item/<%= produto.id %>">
                  <img src="<%= produto.imagem && produto.imagem.startsWith('data:') ? produto.imagem : '/imagem/' + (produto.imagem || 'sem-foto.png') %>" alt="<%= produto.nome %>" onerror="this.src='https://placehold.co/300x200?text=Sem+Foto'">
                </a>
                <figcaption>
                  <h3><%= produto.nome %></h3>
                  <p>R$ <%= parseFloat(produto.preco).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> / tonelada</p>
                  <p>Disponível em <%= produto.local %></p>
                  <a href="/item/<%= produto.id %>">Ver detalhes</a>
                </figcaption>
              </figure>
            </article>
          </li>
        <% }) %>

      <% } %>
    </ul>

    </section>

  </main>
  <%- include('../partial/footer.ejs') %>
  <script src="/js/produto-delete.js"></script>
  <script src="/js/carrossel.js"></script>
  <script src="/js/darkmode.js"></script>
</body>
</html>
