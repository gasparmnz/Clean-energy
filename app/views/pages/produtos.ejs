<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Biomassa Hub - Produtos</title>
  <link rel="stylesheet" href="/css/produtos.css" />
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <link rel="apple-touch-icon" sizes="180x180" href="/imagem/ico.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/imagem/ico.png">
  <meta property="og:locale" contente="pt_BR">
 
<meta property="og:title" content="Clean Energy" />
<meta property="og:description" content="Bobobobobobobobobobobobobobobobobobobobbobobobobobobobobobobo" />
<meta property="og:image" content="" />
<meta property="og:url" content="https://clean-energy.onrender.com/"/>
<meta property="og:type" content="website" />
 
<meta property="og:image:width" content="1200">
<meta property="og:image:height" contente="630">
</head>
<body>
  <%- include('../partial/header.ejs') %>
  <main>
 
    <section class="filtro-container">
  <form class="filtro-box">

    <!-- Barra de busca -->
    <div class="filtro-topo">
      <i class='bx bx-search'></i>
      <input type="text" placeholder="Buscar produtos..." />
    </div>

    <!-- Filtros -->
    <div class="filtro-linha">
      <select>
        <option value="">Estados</option>
        <option>São Paulo</option>
        <option>Rio de Janeiro</option>
        <option>Minas Gerais</option>
        <option>Santa Catarina</option>
        <option>Paraná</option>
      </select>

      <select>
        <option value="">Tipo</option>
        <option>Lenha</option>
        <option>Pellets</option>
        <option>Cavaco</option>
        <option>Bagaço</option>
      </select>

      <input type="number" placeholder="Preço mín." />
      <input type="number" placeholder="Preço máx." />
    </div>

  </form>
</section>
      
      <ul class="produtos-scroll">
  <% produtos.forEach(produto => { %>
    <li>
      <article class="produto-card" data-id="<%= produto.id %>">
        <figure>
          <a href="/item/<%= produto.id %>">
            <img src="/imagem/<%=produto.imagem %>" alt="<%= produto.nome %>">
          </a>
          <figcaption>
            <h3><%= produto.nome %></h3>
            <p>R$ <%= parseFloat(produto.preco).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> / tonelada</p>
            <p>Disponível em <%= produto.local %></p>
            <a href="/item/<%= produto.id %>">Ver detalhes</a>
          </figcaption>
        </figure>
      </article>
    </li>
  <% }) %>
</ul>

    </section>


  </main>
  <%- include('../partial/footer.ejs') %>
  <script src="/js/produto-delete.js"></script>
</body>
</html>
